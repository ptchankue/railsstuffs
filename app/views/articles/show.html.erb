<% content_for :page_title, "#{@article.title} — Rails Stuffs" %>

<div class="page-toolbar">
  <h1><%= @article.title %></h1>
  <div class="page-toolbar__actions">
    <%= link_to "Edit", edit_article_path(@article), class: "btn btn--ghost btn--small" %>
    <%= link_to "Back to list", articles_path, class: "btn btn--ghost btn--small" %>
  </div>
</div>

<article class="article-body">
  <div class="article-body__text"><%= @article.body %></div>
  <p class="article-meta">Created <%= @article.created_at.strftime("%B %d, %Y at %H:%M") %></p>
</article>
